{
  "name": "grocery-catalog-generator",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "tsx scripts/generate-from-manual-screenshots.ts",
    "generate:aldi": "tsx scripts/generate-from-manual-screenshots.ts --stores aldi",
    "generate:sainsburys": "tsx scripts/generate-from-manual-screenshots.ts --stores sainsburys",
    "generate:tesco": "tsx scripts/generate-from-manual-screenshots.ts --stores tesco",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "latest",
    "openai": "latest",
    "playwright": "latest",
    "sharp": "^0.34.5",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
